---
interface Props {
  id?: string;
  eyebrow?: string;
  title?: string;
  sub?: string;
  class?: string;
}
const { id, eyebrow, title, sub, class: cls = '' } = Astro.props;
const hasHead = Boolean(eyebrow || title || sub);
---

<section id={id} class={`section ${cls}`}>
  <div class="container">
    {
      hasHead && (
        <div class="section__head" data-reveal>
          {eyebrow && <p class="eyebrow">{eyebrow}</p>}
          {title && <h2 class="section__title">{title}</h2>}
          {sub && <p class="section__sub">{sub}</p>}
        </div>
      )
    }
    <slot />
  </div>
</section>
