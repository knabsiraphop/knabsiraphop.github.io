---
import { site, nav } from '../data/site';
import Icon from './Icon.astro';
---

<header class="nav">
  <div class="nav__inner container">
    <a class="nav__brand" href="/" aria-label="Home">
      <span class="nav__logo">SP</span>
      <span class="nav__name">{site.name}</span>
    </a>

    <button class="nav__toggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="nav-links" data-nav-toggle>
      <Icon name="menu" size={22} />
    </button>

    <nav id="nav-links" class="nav__links" data-nav-links aria-label="Primary">
      {nav.map((item) => <a class="nav__link" href={item.href}>{item.label}</a>)}
      <a class="nav__icon" href={site.socials.github} target="_blank" rel="noopener" aria-label="GitHub">
        <Icon name="github" size={20} />
      </a>
      <a class="btn btn--primary btn--sm nav__resume" href={site.resume} target="_blank" rel="noopener">
        <Icon name="download" size={16} /> Resume
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const links = document.querySelector<HTMLElement>('[data-nav-links]');
  const header = document.querySelector<HTMLElement>('.nav');

  toggle?.addEventListener('click', () => {
    const open = links?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });

  links?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      links.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    })
  );

  // Subtle solid background once scrolled.
  const onScroll = () => header?.classList.toggle('is-scrolled', window.scrollY > 12);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    transition: background 0.25s ease, border-color 0.25s ease, backdrop-filter 0.25s ease;
    border-bottom: 1px solid transparent;
  }
  .nav.is-scrolled {
    background: rgba(236, 234, 227, 0.82);
    backdrop-filter: blur(12px);
    border-bottom-color: var(--border);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    height: 64px;
  }
  .nav__brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-display);
    font-weight: 600;
    min-width: 0;
  }
  .nav__logo {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: var(--radius);
    font-size: 13px;
    letter-spacing: 0.02em;
    color: var(--accent-ink);
    background: var(--accent);
    flex: none;
  }
  .nav__name {
    font-size: 15px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .nav__links {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .nav__link {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 500;
    color: var(--text-dim);
    transition: color 0.15s ease;
  }
  .nav__link:hover { color: var(--text); }
  .nav__icon {
    display: inline-flex;
    color: var(--text-dim);
    transition: color 0.15s ease;
  }
  .nav__icon:hover { color: var(--text); }
  .nav__toggle {
    display: none;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
  }

  @media (max-width: 760px) {
    .nav__name { display: none; }
    .nav__toggle { display: inline-flex; }
    .nav__links {
      position: absolute;
      top: 64px;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 4px;
      padding: 12px 24px 20px;
      background: rgba(236, 234, 227, 0.98);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      clip-path: inset(0 0 100% 0);
      opacity: 0;
      pointer-events: none;
      transition: clip-path 0.25s ease, opacity 0.25s ease;
    }
    .nav__links.is-open {
      clip-path: inset(0 0 0 0);
      opacity: 1;
      pointer-events: auto;
    }
    .nav__link { padding: 10px 4px; font-size: 17px; border-bottom: 1px solid var(--border); }
    .nav__icon { padding: 10px 4px; }
    .nav__resume { margin-top: 10px; justify-content: center; }
  }
</style>
