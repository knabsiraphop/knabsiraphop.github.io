---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SkillsGrid from '../components/SkillsGrid.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((p) => p.data.featured);

// `git shortlog -sn` of the real work — commit counts from the WorkSummary evidence.
// Bar widths are perceptually scaled so smaller projects stay visible; the numbers are exact.
const shortlog = [
  { commits: '8,379', name: 'ZabbWorld: Secret Stories', note: 'MMO · #1 contributor', bar: 100 },
  { commits: '832', name: 'Dream Runner X', note: 'live-ops systems', bar: 47 },
  { commits: '73', name: 'Pakapow', note: 'guild system · live-ops', bar: 25 },
  { commits: '43', name: 'Cat vs Aliens', note: 'sole programmer', bar: 23 },
  { commits: '42', name: 'Fishing Town', note: '5-day sprint · UI engineer', bar: 22 },
  { commits: '12', name: 'Once Pro Shoot', note: 'sole programmer', bar: 18 },
];

// Top CliftonStrengths themes, framed as they show up in my engineering work.
const strengths = [
  {
    name: 'Context',
    domain: 'Strategic Thinking',
    note: `I read a system by its history — how it got here and why. On a ${site.years}-year MMO codebase, that's the line between a safe change and a regression.`,
  },
  {
    name: 'Deliberative',
    domain: 'Executing',
    note: "I anticipate risks and edge cases before they ship. Cautious by default — it's why my stability and live-ops work holds up.",
  },
  {
    name: 'Maximizer',
    domain: 'Influencing',
    note: "I don't settle for “good enough.” I keep asking how to make a system better — the refactors and optimization passes.",
  },
  {
    name: 'Consistency',
    domain: 'Executing',
    note: 'I build fair, predictable systems and conventions, so a team always knows what to expect from the code.',
  },
  {
    name: 'Harmony',
    domain: 'Relationship Building',
    note: 'I reduce friction and steer toward practical common ground instead of ego debates.',
  },
];
---

<BaseLayout>
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__text" data-reveal>
        <p class="hero__meta">unity game developer · {site.location.toLowerCase()}</p>
        <h1 class="hero__title">Siraphop<br />Puriwattanakul<span class="caret" aria-hidden="true"></span></h1>
        <p class="hero__role">"{site.nick}" — {site.role}</p>
        <p class="hero__tagline">{site.tagline}</p>
        <div class="hero__cta">
          <a class="btn btn--primary" href="/projects/"><Icon name="gamepad" size={17} /> View the work</a>
          <a class="btn" href={site.resume} target="_blank" rel="noopener"><Icon name="download" size={15} /> Resume</a>
        </div>
        <div class="hero__socials">
          <a href={`mailto:${site.email}`} aria-label="Email"><Icon name="mail" size={19} /></a>
          <a href={site.socials.github} target="_blank" rel="noopener" aria-label="GitHub"><Icon name="github" size={19} /></a>
          <a href={site.socials.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn"><Icon name="linkedin" size={19} /></a>
        </div>
      </div>
    </div>

    <!-- SIGNATURE: git shortlog of the real work -->
    <div class="container">
      <div class="shortlog" data-reveal>
        <div class="shortlog__bar">
          <span class="shortlog__dot"></span>
          <span class="shortlog__dot"></span>
          <span class="shortlog__dot"></span>
          <span class="shortlog__cmd">git shortlog -sn --all</span>
        </div>
        <ul class="shortlog__body" data-reveal-group>
          {
            shortlog.map((row) => (
              <li class="log">
                <span class="log__n">{row.commits}</span>
                <span class="log__meter"><span class="log__fill" style={`width:${row.bar}%`} /></span>
                <span class="log__name">{row.name}</span>
                <span class="log__note">{row.note}</span>
              </li>
            ))
          }
        </ul>
        <div class="shortlog__foot">
          <span><strong>10+</strong> titles shipped</span>
          <span><strong>{site.years}</strong> years in production</span>
          <span><strong>3</strong> backends: Nakama · PlayFab · Firebase</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <Section id="about" eyebrow="about" title="Unity developer who ships">
    <div class="about">
      <div class="about__intro">
        <div class="about__text" data-reveal>
          <p>
            I'm a Unity game developer with 6 years building and shipping live mobile and WebGL games in C# at
            Varisoft, a game studio in Bangkok. I'm the lead client engineer on a long-running multiplayer
            life-simulation MMO, and I've been the sole programmer on complete titles shipped end-to-end to Google
            Play, the App Store, and the web — writing all of the code, with art and game design from the teams I
            worked with.
          </p>
          <p>
            I'm strong in gameplay systems, real-time multiplayer (Nakama), live-ops feature delivery, and
            performance / stability work. I'm comfortable owning a project's engineering end-to-end, leading a
            system, or working inside a larger team — and I've shipped against three different backends (Nakama,
            PlayFab, Firebase).
          </p>
          <p class="about__ai">
            <Icon name="code" size={16} /> I own architecture and design decisions personally, and use AI tooling
            (Claude Code with the Unity-MCP plugin) to accelerate implementation, debugging, and testing — I could do it
            without AI, just slower.
          </p>
        </div>
        <figure class="idcard" data-reveal>
          <div class="idcard__photo">
            <img src="/img/headshot.jpg" alt="Siraphop Puriwattanakul" width="526" height="720" loading="lazy" />
          </div>
          <figcaption class="idcard__cap">
            <span class="idcard__k">author</span>
            <span class="idcard__v">Siraphop “Bank” P.</span>
            <span class="idcard__k">since</span>
            <span class="idcard__v">2020 · Bangkok, TH</span>
          </figcaption>
        </figure>
      </div>

      <ul class="about__highlights" data-reveal-group>
        <li><span class="hl__ico"><Icon name="gamepad" size={17} /></span> Lead engineer on a {site.years}-year social MMO</li>
        <li><span class="hl__ico"><Icon name="play" size={15} /></span> Sole programmer on shipped mobile &amp; WebGL titles</li>
        <li><span class="hl__ico"><Icon name="code" size={17} /></span> Live-ops, IAP, gacha &amp; economy systems</li>
        <li><span class="hl__ico"><Icon name="external" size={15} /></span> Open-source Unity packages (UPM)</li>
      </ul>
    </div>
  </Section>

  <!-- ===== EXPERIENCE — the git branch graph (SIGNATURE) ===== -->
  <Section
    id="experience"
    eyebrow="git log --graph"
    title="Career, by branch"
    sub={`${site.years} years on main at Varisoft, with a freelance branch that forked off in 2021 and merged back — read newest-first, like a real log.`}
    class="section--alt"
  >
    <div class="graph" data-reveal-group>
      <!-- HEAD: current work -->
      <div class="grow">
        <div class="rail"><i class="node node--head"></i></div>
        <div class="grow__card surface">
          <div class="grow__top">
            <span class="grow__ref grow__ref--head">HEAD → main</span>
            <span class="grow__when grow__when--now">now</span>
          </div>
          <h3 class="grow__title">Live-ops systems on Dream Runner X</h3>
          <p class="grow__co"><span class="grow__coName">Varisoft</span> · Unity Game Developer</p>
          <p class="grow__body">
            Own core live-ops systems end-to-end — mail, shop + IAP, gachapon, and daily rewards — with 832 commits
            across the build.
          </p>
        </div>
      </div>

      <!-- main: the MMO -->
      <div class="grow">
        <div class="rail"><i class="node"></i></div>
        <div class="grow__card surface">
          <div class="grow__top">
            <span class="grow__ref">main</span>
            <span class="grow__when">2020 – present</span>
          </div>
          <h3 class="grow__title">Lead client engineer · ZabbWorld: Secret Stories</h3>
          <p class="grow__co"><span class="grow__coName">Varisoft</span> · Unity Game Developer</p>
          <p class="grow__body">
            #1 contributor with 8,400+ commits over {site.years}+ years on the studio's flagship social MMO — plus complete
            titles shipped as sole programmer: Cat vs Aliens (Google Play + Huawei AppGallery), Once Pro Shoot and
            Rescue Meow Meow on WebGL. Shipped against Nakama, PlayFab, and Firebase.
          </p>
        </div>
      </div>

      <!-- fork: freelance branch -->
      <div class="grow grow--fork">
        <div class="rail"><i class="node node--branch"></i></div>
        <div class="branch">
          <div class="grow__card grow__card--branch surface">
            <div class="grow__top">
              <span class="grow__ref grow__ref--branch">branch: freelance/*</span>
              <span class="grow__when">2021 – 2022</span>
            </div>
            <h3 class="grow__title">Freelance client work</h3>
            <p class="grow__co"><span class="grow__coName grow__coName--free">Remote</span> · Unity Developer</p>
            <p class="grow__body">
              Standalone tools and a prototype delivered alongside studio work: <strong>Mascot Design</strong> (Spine 2D
              creator with hi-res export), <strong>AvatarCustom</strong> (runtime Spine customization), and
              <strong>SolarYield</strong> (solar-farm sim prototype).
            </p>
          </div>
        </div>
      </div>

      <!-- root: joined -->
      <div class="grow">
        <div class="rail"><i class="node node--root"></i></div>
        <div class="grow__card surface">
          <div class="grow__top">
            <span class="grow__ref">root</span>
            <span class="grow__when">2020</span>
          </div>
          <h3 class="grow__title">Joined Varisoft as a Unity developer</h3>
          <p class="grow__co"><span class="grow__coName">Varisoft</span> · Bangkok, Thailand</p>
          <p class="grow__body">Started on the MMO client and grew into the lead client-engineering role.</p>
        </div>
      </div>
    </div>
  </Section>

  <!-- ===== HOW I WORK ===== -->
  <Section
    id="how-i-work"
    eyebrow="how i work"
    title="Strengths in practice"
    sub="My top CliftonStrengths® 34 themes — and what each one looks like in the code."
  >
    <div class="strengths" data-reveal>
      <ul class="strengths__grid" data-reveal-group>
        {
          strengths.map((s, i) => (
            <li class="strength">
              <div class="strength__top">
                <span class="strength__idx">{String(i + 1).padStart(2, '0')}</span>
                <span class="strength__name">{s.name}</span>
                <span class="strength__domain">{s.domain}</span>
              </div>
              <p class="strength__note">{s.note}</p>
            </li>
          ))
        }
      </ul>
      <div class="strengths__foot">
        <p class="strengths__lead">
          <Icon name="code" size={15} /> I lead with the <strong>Executing</strong> domain — I catch an idea and make it real.
        </p>
        <a class="strengths__credit" href="https://www.gallup.com/cliftonstrengths/" target="_blank" rel="noopener">
          Source: Gallup CliftonStrengths <Icon name="external" size={13} />
        </a>
      </div>
    </div>
  </Section>

  <!-- ===== SKILLS ===== -->
  <Section id="skills" eyebrow="toolbox" title="Skills & tech" class="section--alt">
    <SkillsGrid />
  </Section>

  <!-- ===== FEATURED WORK ===== -->
  <Section
    id="work"
    eyebrow="selected work"
    title="Featured projects"
    sub="A few highlights — some playable right in your browser. See the full list for everything."
  >
    <div class="cards" data-reveal-group>
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="work__more" data-reveal>
      <a class="btn" href="/projects/">All projects <Icon name="arrow" size={17} /></a>
    </div>
  </Section>

  <!-- ===== CONTACT ===== -->
  <Section id="contact" class="section--alt">
    <div class="contact surface" data-reveal>
      <div>
        <p class="eyebrow">get in touch</p>
        <h2 class="contact__title">Looking for a Unity developer?</h2>
        <p class="muted">Open to new opportunities. The fastest way to reach me is email.</p>
      </div>
      <div class="contact__actions">
        <a class="btn btn--primary" href={`mailto:${site.email}`}><Icon name="mail" size={17} /> {site.email}</a>
        <a class="btn" href={site.resume} target="_blank" rel="noopener"><Icon name="download" size={15} /> Resume (PDF)</a>
        <a class="btn btn--ghost" href={site.socials.linkedin} target="_blank" rel="noopener"><Icon name="linkedin" size={17} /> LinkedIn</a>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  /* HERO */
  .hero { padding-top: clamp(28px, 5vw, 56px); padding-bottom: clamp(28px, 4vw, 48px); }
  .hero__text { max-width: 68ch; }
  .hero__meta { font-family: var(--font-mono); color: var(--accent); font-size: 13px; margin-bottom: 18px; }
  .hero__meta::before { content: '✦ '; opacity: 0.85; }
  .hero__title { font-size: clamp(44px, 7.4vw, 78px); line-height: 1.02; letter-spacing: -0.015em; font-weight: 500; }
  .caret {
    display: inline-block;
    width: 0.14em;
    height: 0.82em;
    margin-left: 0.14em;
    transform: translateY(0.04em);
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
    animation: ember-blink 1.4s steps(1) infinite;
  }
  .hero__role { font-family: var(--font-mono); font-size: clamp(14px, 2vw, 17px); font-weight: 500; color: var(--accent-soft); margin-top: 20px; }
  .hero__tagline { color: var(--text-dim); font-size: 16.5px; margin-top: 14px; max-width: 54ch; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 26px; }
  .hero__socials { display: flex; gap: 18px; margin-top: 24px; }
  .hero__socials a { color: var(--text-dim); transition: color 0.15s ease, transform 0.15s ease; }
  .hero__socials a:hover { color: var(--accent); transform: translateY(-2px); }

  /* Author identity card (photo framed like a commit-author block) */
  .idcard { width: 100%; max-width: 236px; border: 1px solid var(--border-strong); border-radius: var(--radius-lg); background: var(--surface); overflow: hidden; box-shadow: var(--shadow); }
  .idcard__photo { position: relative; aspect-ratio: 4 / 5; background: var(--surface-2); border-bottom: 1px solid var(--border); }
  .idcard__photo img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(0.18) contrast(1.03); }
  .idcard__photo::after { content: ''; position: absolute; inset: 0; box-shadow: inset 0 0 44px 8px rgba(12, 10, 21, 0.6); pointer-events: none; }
  .idcard__cap { display: grid; grid-template-columns: auto 1fr; gap: 3px 14px; padding: 14px 16px; font-family: var(--font-mono); font-size: 12.5px; }
  .idcard__k { color: var(--text-dim); }
  .idcard__k::after { content: ':'; }
  .idcard__v { color: var(--text); }

  /* SIGNATURE — git shortlog */
  .shortlog {
    margin-top: clamp(34px, 5vw, 56px);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    background: var(--surface);
    overflow: hidden;
    box-shadow: var(--shadow);
  }
  .shortlog__bar { display: flex; align-items: center; gap: 8px; padding: 11px 16px; background: var(--surface-2); border-bottom: 1px solid var(--border); }
  .shortlog__dot { width: 10px; height: 10px; border-radius: 50%; border: 1px solid var(--border-strong); }
  .shortlog__dot:nth-child(1) { background: var(--accent); box-shadow: 0 0 7px rgba(212, 162, 76, 0.6); }
  .shortlog__dot:nth-child(2) { background: var(--accent-2); box-shadow: 0 0 7px rgba(156, 123, 214, 0.6); }
  .shortlog__dot:nth-child(3) { background: #5a5170; }
  .shortlog__cmd { font-family: var(--font-mono); font-size: 13px; color: var(--text-dim); margin-left: 8px; }
  .shortlog__cmd::before { content: '$ '; color: var(--accent); }
  .shortlog__body { padding: 8px 6px; }
  .log {
    display: grid;
    grid-template-columns: 58px minmax(90px, 150px) 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 7px 12px;
    font-family: var(--font-mono);
    border-radius: var(--radius);
  }
  .log:hover { background: rgba(212, 162, 76, 0.06); }
  .log__n { text-align: right; font-weight: 600; font-size: 15px; color: var(--accent-soft); font-variant-numeric: tabular-nums; }
  .log__meter { height: 8px; border-radius: 999px; background: var(--surface-2); overflow: hidden; }
  .log__fill {
    display: block;
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--accent-soft));
    border-radius: 999px;
    transform-origin: left;
    transition: transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
  }
  html.js .shortlog[data-reveal]:not(.is-in) .log__fill { transform: scaleX(0); }
  .log__name { font-size: 14px; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .log__note { font-size: 12.5px; color: var(--text-dim); white-space: nowrap; }
  .shortlog__foot { display: flex; flex-wrap: wrap; gap: 8px 26px; padding: 14px 18px; border-top: 1px solid var(--border); font-family: var(--font-mono); font-size: 13px; color: var(--text-dim); }
  .shortlog__foot strong { color: var(--accent); font-weight: 600; }

  /* ABOUT */
  .about__intro { display: grid; grid-template-columns: 1.55fr auto; gap: clamp(28px, 5vw, 56px); align-items: start; }
  .about__text p { color: var(--prose); margin-bottom: 16px; font-size: 16.5px; }
  .about__text p:last-child { margin-bottom: 0; }
  .about__ai { display: flex; gap: 10px; align-items: start; color: var(--text-dim) !important; font-size: 15px !important; border-left: 2px solid var(--accent); padding-left: 14px; margin-top: 20px; }
  .about__ai :global(.icon) { color: var(--accent); margin-top: 3px; }

  /* capability band — full-width row under the intro */
  .about__highlights { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-top: clamp(30px, 4vw, 44px); }
  .about__highlights li {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 18px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    font-family: var(--font-mono);
    font-size: 13.5px;
    font-weight: 500;
    line-height: 1.45;
    transition: border-color 0.18s ease, transform 0.18s ease;
  }
  .about__highlights li:hover { border-color: var(--accent); transform: translateY(-3px); }
  .hl__ico { display: grid; place-items: center; width: 38px; height: 38px; border-radius: var(--radius); background: var(--surface-2); border: 1px solid var(--border); color: var(--accent); }

  /* EXPERIENCE — git branch graph */
  .graph { max-width: 780px; }
  .grow { display: grid; grid-template-columns: 40px 1fr; }
  .rail { position: relative; }
  /* continuous vertical line down the rail */
  .rail::before { content: ''; position: absolute; left: 50%; top: 0; bottom: 0; width: 2px; margin-left: -1px; background: var(--border-strong); }
  .grow:first-child .rail::before { top: 22px; }
  .grow:last-child .rail::before { bottom: calc(100% - 22px); }
  .node {
    position: absolute;
    left: 50%;
    top: 14px;
    width: 15px;
    height: 15px;
    margin-left: -7.5px;
    border-radius: 50%;
    background: var(--surface);
    border: 2px solid var(--accent);
    z-index: 1;
  }
  .node--head { background: var(--accent); box-shadow: 0 0 0 4px rgba(212, 162, 76, 0.18), 0 0 16px -2px var(--accent); }
  .node--root { border-style: dashed; }
  .node { transition: transform 0.4s ease 0.15s, opacity 0.4s ease 0.15s; }
  html.js .graph[data-reveal-group]:not(.is-in) .node { transform: scale(0); opacity: 0; }
  .grow__card { padding: 18px 20px; margin: 0 0 16px 8px; }
  .grow__top { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 6px 14px; margin-bottom: 10px; }
  .grow__ref {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: var(--radius);
    color: var(--text-dim);
    background: var(--surface-2);
    border: 1px solid var(--border);
  }
  .grow__ref--head { color: var(--accent-ink); background: var(--accent); border-color: var(--accent); }
  .grow__ref--branch { color: var(--accent-2); border-color: rgba(156, 123, 214, 0.4); background: rgba(156, 123, 214, 0.1); }
  .grow__when { font-family: var(--font-mono); font-size: 12.5px; color: var(--text-dim); }
  .grow__when--now { color: var(--accent); }
  .grow__title { font-size: 17px; letter-spacing: -0.02em; }
  .grow__co { font-family: var(--font-mono); font-size: 13px; margin-top: 4px; color: var(--text-dim); }
  .grow__coName { color: var(--accent); font-weight: 500; }
  .grow__coName--free { color: var(--accent-2); }
  .grow__body { color: var(--prose); font-size: 14.5px; margin-top: 10px; line-height: 1.55; }

  /* fork: branch node + indented branch card with an elbow connector */
  .node--branch { border-color: var(--accent-2); }
  .grow--fork .rail::after {
    content: '';
    position: absolute;
    left: 50%;
    top: 21px;
    width: 26px;
    height: 20px;
    border-left: 2px solid var(--accent-2);
    border-bottom: 2px solid var(--accent-2);
    border-bottom-left-radius: 10px;
    transform: translateX(-1px) scaleX(-1);
  }
  .branch { padding-left: 26px; }
  .grow__card--branch { border-style: dashed; border-color: rgba(156, 123, 214, 0.45); background: rgba(156, 123, 214, 0.05); }

  /* HOW I WORK (strengths) */
  .strengths__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; }
  .strength { padding: 16px 18px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); transition: border-color 0.18s ease, transform 0.18s ease; }
  .strength:hover { border-color: var(--accent); transform: translateY(-2px); }
  .strength__top { display: flex; align-items: baseline; gap: 8px; margin-bottom: 8px; }
  .strength__idx { font-family: var(--font-mono); font-size: 11px; color: var(--text-dim); }
  .strength__name { font-family: var(--font-display); font-weight: 500; font-size: 18px; letter-spacing: 0; color: var(--text); }
  .strength__domain { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--accent-2); white-space: nowrap; margin-left: auto; }
  .strength__note { color: var(--prose); font-size: 14px; line-height: 1.5; }
  .strengths__foot { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 14px; margin-top: 20px; }
  .strengths__lead { display: inline-flex; align-items: center; gap: 8px; color: var(--text-dim); font-size: 14.5px; border-left: 2px solid var(--accent); padding-left: 12px; }
