---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SkillsGrid from '../components/SkillsGrid.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Icon from '../components/Icon.astro';
import { site } from '../data/site';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const featured = projects.filter((p) => p.data.featured);

const stats = [
  { value: '6+', label: 'Years building & shipping Unity games' },
  { value: '10+', label: 'Titles across mobile & WebGL' },
  { value: '8,400+', label: 'Commits on the flagship MMO (#1 contributor)' },
];

// Top CliftonStrengths themes, framed as they show up in my engineering work.
const strengths = [
  {
    name: 'Context',
    domain: 'Strategic Thinking',
    note: "I read a system by its history — how it got here and why. On a five-year MMO codebase, that's the line between a safe change and a regression.",
  },
  {
    name: 'Deliberative',
    domain: 'Executing',
    note: "I anticipate risks and edge cases before they ship. Cautious by default — it's why my stability and live-ops work holds up.",
  },
  {
    name: 'Maximizer',
    domain: 'Influencing',
    note: "I don't settle for “good enough.” I keep asking how to make a system better — the refactors and optimization passes.",
  },
  {
    name: 'Consistency',
    domain: 'Executing',
    note: 'I build fair, predictable systems and conventions, so a team always knows what to expect from the code.',
  },
  {
    name: 'Harmony',
    domain: 'Relationship Building',
    note: 'I reduce friction and steer toward practical common ground instead of ego debates.',
  },
];

// Career path — where I've worked and what I shipped there.
const experience = [
  {
    company: 'Varisoft',
    role: 'Unity Game Developer',
    period: '2020 – Present',
    location: 'Bangkok, Thailand',
    current: true,
    blurb:
      "Joined as a Unity developer and grew into the lead client engineer on the studio's flagship MMO — while shipping several smaller titles end-to-end as the sole programmer.",
    points: [
      'Lead client engineer on ZabbWorld: Secret Stories — #1 contributor with 8,400+ commits across 5+ years.',
      'Sole programmer on shipped titles: Cat vs Aliens (Huawei AppGallery), plus Once Pro Shoot and Rescue Meow Meow on WebGL.',
      'Now own core live-ops systems — mail, shop + IAP, gachapon, daily rewards — on Dream Runner X.',
      'Shipped against three backends: Nakama (real-time multiplayer), PlayFab, and Firebase.',
    ],
  },
  {
    company: 'Freelance',
    role: 'Unity Developer',
    period: '2021 – 2022',
    location: 'Remote',
    current: false,
    blurb: 'Delivered standalone Unity tools and a game prototype for external clients, alongside my studio work.',
    points: [
      'Mascot Design — a Spine 2D mascot-creator desktop app with high-resolution export.',
      'AvatarCustom — a runtime Spine avatar-customization system.',
      'SolarYield — a solar-farm simulation game prototype.',
    ],
  },
];
---

<BaseLayout>
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__text" data-reveal>
        <p class="hero__loc"><Icon name="pin" size={15} /> {site.location}</p>
        <h1 class="hero__title">Siraphop<br /><span>Puriwattanakul</span></h1>
        <p class="hero__role">{site.role} <span>· "{site.nick}"</span></p>
        <p class="hero__tagline">{site.tagline}</p>
        <div class="hero__cta">
          <a class="btn btn--primary" href="/projects/"><Icon name="gamepad" size={18} /> View my work</a>
          <a class="btn" href={site.resume} target="_blank" rel="noopener"><Icon name="download" size={16} /> Resume</a>
        </div>
        <div class="hero__socials">
          <a href={`mailto:${site.email}`} aria-label="Email"><Icon name="mail" size={20} /></a>
          <a href={site.socials.github} target="_blank" rel="noopener" aria-label="GitHub"><Icon name="github" size={20} /></a>
          <a href={site.socials.linkedin} target="_blank" rel="noopener" aria-label="LinkedIn"><Icon name="linkedin" size={20} /></a>
        </div>
      </div>
      <div class="hero__media" data-reveal>
        <div class="hero__photo">
          <img src="/img/headshot.jpg" alt="Siraphop Puriwattanakul" width="526" height="720" loading="eager" />
        </div>
        <span class="hero__ring" aria-hidden="true"></span>
      </div>
    </div>

    <div class="container">
      <div class="hero__stats" data-reveal-group>
        {
          stats.map((s) => (
            <div class="stat">
              <span class="stat__value">{s.value}</span>
              <span class="stat__label">{s.label}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <Section id="about" eyebrow="About" title="Senior Unity developer who ships">
    <div class="about">
      <div class="about__text" data-reveal>
        <p>
          I'm a Unity game developer with 6 years building and shipping live mobile and WebGL games in C# at
          Varisoft, a game studio in Bangkok. I'm the lead client engineer on a long-running multiplayer
          life-simulation MMO, and I've been the sole programmer on complete titles shipped end-to-end to Google
          Play, the App Store, and the web — writing all of the code, with art and game design from the teams I
          worked with.
        </p>
        <p>
          I'm strong in gameplay systems, real-time multiplayer (Nakama), live-ops feature delivery, and
          performance / stability work. I'm comfortable owning a project's engineering end-to-end, leading a
          system, or working inside a larger team — and I've shipped against three different backends (Nakama,
          PlayFab, Firebase).
        </p>
        <p class="about__ai">
          <Icon name="code" size={16} /> I own architecture and design decisions personally, and use AI tooling
          (Claude Code with the Unity-MCP plugin) to accelerate implementation, debugging, and testing — I could do it
          without AI, just slower.
        </p>
      </div>
      <ul class="about__highlights" data-reveal-group>
        <li><Icon name="gamepad" size={18} /> Lead engineer on a 5-year social MMO</li>
        <li><Icon name="play" size={16} /> Sole programmer on shipped mobile & WebGL titles</li>
        <li><Icon name="code" size={18} /> Live-ops, IAP, gacha & economy systems</li>
        <li><Icon name="external" size={16} /> Open-source Unity packages (UPM)</li>
      </ul>
    </div>
  </Section>

  <!-- ===== EXPERIENCE / CAREER PATH ===== -->
  <Section
    id="experience"
    eyebrow="Career path"
    title="Where I've worked"
    sub="Six years shipping Unity games — full-time at a studio, plus freelance client work on the side."
    class="section--alt"
  >
    <ol class="xp" data-reveal-group>
      {
        experience.map((job) => (
          <li class="xp__item">
            <span class="xp__dot" aria-hidden="true" />
            <div class="xp__card surface">
              <div class="xp__top">
                <div>
                  <h3 class="xp__role">{job.role}</h3>
                  <p class="xp__co">
                    <span class="xp__coName">{job.company}</span>
                    <span class="muted"> · {job.location}</span>
                  </p>
                </div>
                <span class:list={['xp__period', { 'xp__period--now': job.current }]}>{job.period}</span>
              </div>
              <p class="xp__blurb">{job.blurb}</p>
              <ul class="xp__points">
                {job.points.map((pt) => (
                  <li>{pt}</li>
                ))}
              </ul>
            </div>
          </li>
        ))
      }
    </ol>
  </Section>

  <!-- ===== HOW I WORK ===== -->
  <Section
    id="how-i-work"
    eyebrow="How I work"
    title="Strengths in practice"
    sub="My top CliftonStrengths® 34 themes — and what each one looks like in the code."
  >
    <div class="strengths" data-reveal>
      <ul class="strengths__grid" data-reveal-group>
        {
          strengths.map((s) => (
            <li class="strength">
              <div class="strength__top">
                <span class="strength__name">{s.name}</span>
                <span class="strength__domain">{s.domain}</span>
              </div>
              <p class="strength__note">{s.note}</p>
            </li>
          ))
        }
      </ul>
      <div class="strengths__foot">
        <p class="strengths__lead">
          <Icon name="code" size={15} /> I lead with the <strong>Executing</strong> domain — I catch an idea and make it real.
        </p>
        <a class="strengths__credit" href="https://www.gallup.com/cliftonstrengths/" target="_blank" rel="noopener">
          Source: Gallup CliftonStrengths <Icon name="external" size={13} />
        </a>
      </div>
    </div>
  </Section>

  <!-- ===== SKILLS ===== -->
  <Section id="skills" eyebrow="Toolbox" title="Skills & tech" class="section--alt">
    <SkillsGrid />
  </Section>

  <!-- ===== FEATURED WORK ===== -->
  <Section
    id="work"
    eyebrow="Selected work"
    title="Featured projects"
    sub="A few highlights — some playable right in your browser. See the full list for everything."
  >
    <div class="cards" data-reveal-group>
      {featured.map((project) => <ProjectCard project={project} />)}
    </div>
    <div class="work__more" data-reveal>
      <a class="btn" href="/projects/">All projects <Icon name="arrow" size={18} /></a>
    </div>
  </Section>

  <!-- ===== CONTACT ===== -->
  <Section id="contact" class="section--alt">
    <div class="contact surface" data-reveal>
      <div>
        <p class="eyebrow">Get in touch</p>
        <h2 class="contact__title">Looking for a senior Unity developer?</h2>
        <p class="muted">Open to new opportunities. The fastest way to reach me is email.</p>
      </div>
      <div class="contact__actions">
        <a class="btn btn--primary" href={`mailto:${site.email}`}><Icon name="mail" size={18} /> {site.email}</a>
        <a class="btn" href={site.resume} target="_blank" rel="noopener"><Icon name="download" size={16} /> Resume (PDF)</a>
        <a class="btn btn--ghost" href={site.socials.linkedin} target="_blank" rel="noopener"><Icon name="linkedin" size={18} /> LinkedIn</a>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  /* HERO */
  .hero { padding-top: clamp(32px, 6vw, 64px); padding-bottom: clamp(32px, 5vw, 56px); }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.4fr 0.9fr;
    gap: 40px;
    align-items: center;
  }
  .hero__loc { display: inline-flex; align-items: center; gap: 6px; color: var(--text-dim); font-size: 14px; margin-bottom: 18px; }
  .hero__title { font-size: clamp(40px, 7vw, 72px); line-height: 0.98; letter-spacing: -0.02em; }
  .hero__title span {
    background: linear-gradient(120deg, var(--accent), var(--accent-2), var(--accent));
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: gradient-pan 6s linear infinite;
  }
  .hero__role { font-family: var(--font-display); font-size: clamp(16px, 2.2vw, 20px); font-weight: 600; color: var(--text); margin-top: 16px; }
  .hero__role span { color: var(--text-dim); font-weight: 500; }
  .hero__tagline { color: var(--text-dim); font-size: 17px; margin-top: 14px; max-width: 56ch; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 26px; }
  .hero__socials { display: flex; gap: 16px; margin-top: 24px; }
  .hero__socials a { color: var(--text-dim); transition: color 0.15s ease, transform 0.15s ease; }
  .hero__socials a:hover { color: var(--accent); transform: translateY(-2px); }

  .hero__media { position: relative; justify-self: center; }
  .hero__photo {
    position: relative;
    width: clamp(220px, 30vw, 320px);
    aspect-ratio: 1;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface-2);
    box-shadow: var(--shadow);
    z-index: 1;
  }
  .hero__photo img { width: 100%; height: 100%; object-fit: cover; }
  .hero__media { animation: float-y 7s ease-in-out infinite; }
  .hero__ring {
    position: absolute;
    inset: -14px;
    border-radius: 32px;
    background: linear-gradient(135deg, rgba(77, 163, 255, 0.5), rgba(0, 229, 199, 0.4));
    filter: blur(26px);
    opacity: 0.5;
    z-index: 0;
    animation: glow-pulse 5s ease-in-out infinite;
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: clamp(36px, 6vw, 64px);
    padding: 22px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.02), transparent);
  }
  .stat { display: flex; flex-direction: column; gap: 4px; text-align: center; }
  .stat__value { font-family: var(--font-display); font-size: clamp(24px, 4vw, 34px); font-weight: 700; color: var(--accent); }
  .stat__label { font-size: 13px; color: var(--text-dim); }

  /* ABOUT */
  .about { display: grid; grid-template-columns: 1.5fr 1fr; gap: 36px; align-items: start; }
  .about__text p { color: #cfd8e2; margin-bottom: 16px; font-size: 16.5px; }
  .about__ai { display: flex; gap: 10px; align-items: start; color: var(--text-dim) !important; font-size: 15px !important; border-left: 2px solid var(--accent); padding-left: 14px; }
  .about__ai :global(.icon) { color: var(--accent); margin-top: 3px; }
  .about__highlights { display: grid; gap: 12px; }
  .about__highlights li { display: flex; align-items: center; gap: 12px; padding: 14px 16px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); font-family: var(--font-display); font-size: 15px; font-weight: 500; }
  .about__highlights :global(.icon) { color: var(--accent-2); }

  /* HOW I WORK (strengths) */
  .strengths__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; }
  .strength { padding: 16px 18px; border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); transition: border-color 0.18s ease, transform 0.18s ease; }
  .strength:hover { border-color: rgba(77, 163, 255, 0.5); transform: translateY(-2px); }
  .strength__top { display: flex; align-items: baseline; justify-content: space-between; gap: 10px; margin-bottom: 8px; }
  .strength__name { font-family: var(--font-display); font-weight: 700; font-size: 16px; }
  .strength__domain { font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent-2); white-space: nowrap; }
  .strength__note { color: #cfd8e2; font-size: 14px; line-height: 1.5; }
  .strengths__foot { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 14px; margin-top: 20px; }
  .strengths__lead { display: inline-flex; align-items: center; gap: 8px; color: var(--text-dim); font-size: 14.5px; border-left: 2px solid var(--accent); padding-left: 12px; }
  .strengths__lead :global(.icon) { color: var(--accent); }
  .strengths__lead strong { color: var(--text); }
  .strengths__credit { display: inline-flex; align-items: center; gap: 6px; color: var(--text-dim); font-size: 12.5px; transition: color 0.15s ease; }
  .strengths__credit:hover { color: var(--accent); }

  /* EXPERIENCE (career timeline) */
  .xp { display: grid; gap: 0; max-width: 840px; list-style: none; padding: 0; margin: 0; }
  .xp__item { position: relative; padding: 0 0 20px 34px; }
  .xp__item:last-child { padding-bottom: 0; }
  .xp__item::before {
    content: '';
    position: absolute;
    left: 9px;
    top: 8px;
    bottom: 0;
    width: 2px;
    background: var(--border);
  }
  .xp__item:last-child::before { display: none; }
  .xp__dot {
    position: absolute;
    left: 2px;
    top: 6px;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--surface);
    border: 2px solid var(--accent);
    box-shadow: 0 0 0 4px rgba(77, 163, 255, 0.12);
  }
  .xp__card { padding: 20px 22px; }
  .xp__top { display: flex; flex-wrap: wrap; align-items: baseline; justify-content: space-between; gap: 6px 16px; margin-bottom: 12px; }
  .xp__role { font-size: 18px; }
  .xp__co { font-size: 14px; margin-top: 3px; }
  .xp__coName { font-family: var(--font-display); font-weight: 600; color: var(--accent); }
  .xp__period {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-dim);
    white-space: nowrap;
    padding: 3px 10px;
    border: 1px solid var(--border);
    border-radius: 999px;
  }
  .xp__period--now { color: var(--accent-2); border-color: rgba(0, 229, 199, 0.35); }
  .xp__blurb { color: #cfd8e2; font-size: 15px; margin-bottom: 14px; }
  .xp__points { display: grid; gap: 9px; }
  .xp__points li { position: relative; padding-left: 22px; color: #cfd8e2; font-size: 14.5px; line-height: 1.5; }
  .xp__points li::before {
    content: '';
    position: absolute;
    left: 3px;
    top: 8px;
    width: 7px;
    height: 7px;
    border-radius: 2px;
    background: var(--accent);
    transform: rotate(45deg);
  }

  /* shared section bg */
  :global(.section--alt) { background: rgba(255, 255, 255, 0.014); border-block: 1px solid var(--border); }

  /* CARDS GRID */
  .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 22px; }
  .work__more { display: flex; justify-content: center; margin-top: 36px; }

  /* CONTACT */
  .contact { display: flex; flex-wrap: wrap; gap: 24px; align-items: center; justify-content: space-between; padding: clamp(26px, 4vw, 44px); }
  .contact__title { font-size: clamp(22px, 3vw, 30px); margin: 8px 0; }
  .contact__actions { display: flex; flex-wrap: wrap; gap: 12px; }

  @media (max-width: 860px) {
    .hero__grid { grid-template-columns: 1fr; gap: 28px; }
    .hero__media { order: -1; justify-self: start; }
    .about { grid-template-columns: 1fr; gap: 24px; }
  }
  @media (max-width: 560px) {
    .hero__stats { grid-template-columns: 1fr; gap: 18px; }
    .hero__title { font-size: clamp(36px, 12vw, 52px); }
  }
</style>

<script>
  // Count-up the hero stats when they scroll into view (respects reduced motion).
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const stats = document.querySelectorAll<HTMLElement>('.stat__value');
  if (!reduce && 'IntersectionObserver' in window && stats.length) {
    const fmt = (n: number) => n.toLocaleString('en-US');
    const run = (el: HTMLElement) => {
      const raw = (el.textContent || '').trim();
      const m = raw.match(/([\d,]+)/);
      if (!m) return;
      const target = parseInt(m[1].replace(/,/g, ''), 10);
      const prefix = raw.slice(0, m.index);
      const suffix = raw.slice((m.index || 0) + m[1].length);
      const dur = 1400;
      const start = performance.now();
      const tick = (now: number) => {
        const p = Math.min((now - start) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = prefix + fmt(Math.round(target * eased)) + suffix;
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            run(e.target as HTMLElement);
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.5 }
    );
    stats.forEach((s) => io.observe(s));
  }
</script>
