---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout title="Page not found" description="That page doesn't exist.">
  <section class="nf">
    <div class="container">
      <p class="nf__code">404</p>
      <h1 class="nf__title">This level doesn't exist.</h1>
      <p class="muted">The page you're looking for moved or was never here.</p>
      <div class="nf__cta">
        <a class="btn btn--primary" href="/"><Icon name="arrow" size={16} /> Back to home</a>
        <a class="btn" href="/projects/"><Icon name="gamepad" size={16} /> See projects</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf { padding-block: clamp(80px, 16vw, 180px); text-align: center; }
  .nf__code {
    font-family: var(--font-display);
    font-size: clamp(72px, 18vw, 160px);
    font-weight: 700;
    line-height: 1;
    background: linear-gradient(120deg, var(--accent), var(--accent-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .nf__title { font-size: clamp(24px, 4vw, 36px); margin: 8px 0 12px; }
  .nf__cta { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 28px; }
</style>
