# Normalize text files to LF in the repo (keeps the Linux CI build deterministic).
* text=auto eol=lf

# Treat binary assets as binary (never line-ending-converted).
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.mp4 binary
*.wasm binary
